// Vocabulary Learning Web App — Prisma schema
// PostgreSQL (DATABASE_URL)
// Note: `tags`/`synonyms`/`antonyms` lưu dạng JSON string cho gọn, parse khi đọc

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Deck {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#3b82f6")
  icon        String?
  // Cột tùy chỉnh dạng bảng (Excel-like): JSON [{id,name,values:{cardId:value}}]
  customColumns String @default("[]")
  // Đánh dấu "đã học xong" (thủ công). null = chưa học xong. Dùng cho khóa tuần tự kiểu Duolingo.
  learnedAt   DateTime?
  // Soft delete: null = đang dùng, có giá trị = đã chuyển vào thùng rác
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cards       Card[]
  stories     Story[]
  activities  DeckActivity[]
  attempts    ExerciseAttempt[]

  @@index([deletedAt])
}

// Theo dõi hoàn thành từng dạng bài tập của một deck (để biết "đã làm hết bài tập chưa").
model DeckActivity {
  id           String   @id @default(cuid())
  deckId       String
  deck         Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  // Loại hoạt động: study | multiple-choice | typing | listening | gap-fill | word-formation | matching | test | flashcards | pronounce
  activity     String
  // Độ chính xác tốt nhất (0-100). null = dạng không chấm điểm (matching, flashcards)
  bestAccuracy Int?
  // JSON array ID các thẻ làm SAI ở LẦN GẦN NHẤT (ghi đè mỗi lần làm) — để đánh dấu "lần trước bạn sai từ này"
  wrongCardIds String   @default("[]")
  completedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([deckId, activity])
  @@index([deckId])
}

// Nhật ký TỪNG LẦN làm bài tập (append-only) — dùng cho trang "Lịch sử làm bài"
// và tổng hợp "Câu sai cần ôn" (cộng dồn qua các lần, không ghi đè).
model ExerciseAttempt {
  id           String   @id @default(cuid())
  deckId       String
  deck         Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  // Loại hoạt động (giống DeckActivity.activity)
  activity     String
  // Độ chính xác lượt này (0-100). null = dạng không chấm điểm.
  accuracy     Int?
  // Tổng số câu trong lượt & số câu sai.
  totalCount   Int      @default(0)
  wrongCount   Int      @default(0)
  // JSON array ID các thẻ làm sai trong lượt này.
  wrongCardIds String   @default("[]")
  createdAt    DateTime @default(now())

  @@index([deckId])
  @@index([createdAt])
}

model Card {
  id                 String   @id @default(cuid())
  deckId             String
  deck               Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)

  word               String
  meaning            String
  partOfSpeech       String?
  // Từ gốc + loại từ, vd "progress (noun, verb)" — hiển thị nguồn gốc của từ
  rootWord           String?
  // Nghĩa tiếng Việt của từ gốc, vd "tiến bộ; sự tiến triển"
  rootWordMeaning    String?
  phonetic           String?
  example            String?
  exampleTranslation String?
  note               String?
  imageUrl           String?
  audioUrl           String?
  tags               String   @default("[]")
  order              Int      @default(0)
  // JSON các dạng từ cho bài word formation: {"noun":..,"verb":..,"adjective":..,"adverb":..}
  wordForms          String?
  // JSON nghĩa tiếng Việt cho từng dạng từ: {"noun":"năng lực","verb":"làm cho có thể",..}
  wordFormMeanings   String?
  // JSON array từ đồng nghĩa / trái nghĩa, vd ["happy","glad"]
  synonyms           String?
  antonyms           String?
  // Đánh dấu từ yêu thích — bật/tắt bằng icon ngôi sao
  favorite           Boolean  @default(false)

  easeFactor         Float    @default(2.5)
  interval           Int      @default(0)
  repetitions        Int      @default(0)
  nextReviewDate     DateTime @default(now())
  state              String   @default("NEW")
  lapses             Int      @default(0)

  // Soft delete: null = đang dùng, có giá trị = đã chuyển vào thùng rác
  deletedAt          DateTime?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  reviewLogs         ReviewLog[]
  storyCards         StoryCard[]

  @@index([deckId])
  @@index([nextReviewDate])
  @@index([state])
  @@index([deletedAt])
  @@index([favorite])
}

model ReviewLog {
  id               String   @id @default(cuid())
  cardId           String
  card             Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  rating           Int
  reviewedAt       DateTime @default(now())
  timeTakenMs      Int      @default(0)
  previousInterval Int      @default(0)
  newInterval      Int      @default(0)

  @@index([cardId])
  @@index([reviewedAt])
}

model DailyStat {
  id            String   @id @default(cuid())
  date          DateTime @unique
  cardsReviewed Int      @default(0)
  cardsLearned  Int      @default(0)
  correctCount  Int      @default(0)
  totalCount    Int      @default(0)
  timeSpentSec  Int      @default(0)
}

model UserProgress {
  id              String    @id @default("singleton")
  // Hồ sơ cá nhân
  displayName     String?
  // Avatar lưu dạng data URL (base64) hoặc URL ngoài
  avatarUrl       String?
  bio             String?
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastStudyDate   DateTime?
  dailyGoal       Int       @default(20)
  freezeTokens    Int       @default(2)
}

model Achievement {
  id         String   @id
  unlockedAt DateTime @default(now())
}

model Story {
  id         String      @id @default(cuid())
  deckId     String
  deck       Deck        @relation(fields: [deckId], references: [id], onDelete: Cascade)

  title      String
  content    String
  contentEn  String?
  imageUrl   String?
  audioUrl   String?

  readCount  Int         @default(0)
  lastReadAt DateTime?

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  storyCards StoryCard[]

  @@index([deckId])
}

model StoryCard {
  id      String @id @default(cuid())
  storyId String
  story   Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)
  cardId  String
  card    Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  order   Int

  @@unique([storyId, cardId])
  @@index([storyId])
  @@index([cardId])
}
