# Database — PostgreSQL (Neon / Supabase / Vercel Postgres)
# Định dạng: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
# Neon/Supabase nên dùng connection pooling URL cho serverless (host có "-pooler").
# QUAN TRỌNG (Neon): compute serverless tự "ngủ" sau ~5 phút không dùng. Lần gọi đầu
# phải chờ compute wake (~2-5s) — thêm connect_timeout=30 để tránh lỗi P1001
# "Can't reach database server" do timeout mặc định quá ngắn.
DATABASE_URL="postgresql://user:password@host-pooler:5432/dbname?sslmode=require&connect_timeout=30&pgbouncer=true"

# (Tuỳ chọn) Bảo vệ truy cập bằng Basic Auth — đặt cả 2 biến để bật.
# Bỏ trống = không yêu cầu đăng nhập (KHÔNG nên cho bản public).
BASIC_AUTH_USER=""
BASIC_AUTH_PASSWORD=""

# Claude API — chỉ dùng cho script sinh ví dụ (scripts/generate-examples.ts), KHÔNG cần lúc chạy app
# Lấy key tại: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-xxxxxxxx"
ANTHROPIC_MODEL="claude-sonnet-4-6"
