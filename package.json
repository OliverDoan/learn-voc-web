{
  "name": "learn-voc-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "import:vocab": "tsx --env-file=.env scripts/import-vocab-full.ts",
    "gen:examples": "tsx --env-file=.env scripts/generate-examples.ts",
    "data:synonyms": "tsx --env-file=.env scripts/fill-synonyms.ts",
    "gen:synonyms": "tsx --env-file=.env scripts/generate-synonyms.ts",
    "gen:root-meanings": "tsx --env-file=.env scripts/generate-root-meanings.ts",
    "gen:examples:dict": "tsx --env-file=.env scripts/generate-examples-dict.ts",
    "data:export": "tsx --env-file=.env scripts/export-data.ts",
    "data:load": "tsx --env-file=.env scripts/load-data.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "@prisma/client": "^6.19.3",
    "@tanstack/react-query": "^5.100.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "^4.1.7",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "@prisma/client",
      "esbuild"
    ]
  }
}
